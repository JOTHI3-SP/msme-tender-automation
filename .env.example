# Google Gemini API for Document Intelligence
GOOGLE_API_KEY=your_gemini_api_key_here

# Groq API for Fast Document Analysis
GROQ_API_KEY=your_groq_api_key_here

# Green API WhatsApp Integration
GREEN_API_INSTANCE_ID=your_green_api_instance_id
GREEN_API_ACCESS_TOKEN=your_green_api_access_token
USER_WHATSAPP_NUMBER=919876543210

# Database Configuration
DATABASE_URL=sqlite:///./tender_system.db

# Portal URLs for Monitoring
GEM_PORTAL_URL=https://bidplus.gem.gov.in/all-bids
CPPP_PORTAL_URL=https://eprocure.gov.in

# System Configuration
MONITORING_INTERVAL_MINUTES=15
DOCUMENT_PROCESSING_TIMEOUT_MINUTES=5

# Company Profile (Default - can be updated via UI)
COMPANY_NAME=Your Company Name
COMPANY_TURNOVER_LAKHS=50
COMPANY_EXPERIENCE_YEARS=5
COMPANY_LOCATION=Coimbatore, Tamil Nadu
COMPANY_SECTOR=pump,textile